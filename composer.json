{
    "name": "kode/queue",
    "description": "一个现代化、高性能的 PHP 队列客户端，支持多种队列驱动，专为 PHP 8.1+ 设计，完美支持 PHP 8.5 管道操作符新特性",
    "type": "library",
    "version": "1.3.0",
    "keywords": [
        "queue",
        "redis",
        "beanstalkd",
        "amqp",
        "database",
        "sync",
        "kafka",
        "php",
        "php81",
        "php85",
        "pipeline",
        "队列",
        "消息队列"
    ],
    "homepage": "https://github.com/kodephp/queue",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "KodePHP Team",
            "email": "382601296@qq.com",
            "homepage": "https://kodephp.com"
        }
    ],
    "support": {
        "issues": "https://github.com/kodephp/queue/issues",
        "source": "https://github.com/kodephp/queue",
        "docs": "https://github.com/kodephp/queue#readme"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.0"
    },
    "suggest": {
        "predis/predis": "Redis 驱动所需",
        "pda/pheanstalk": "Beanstalkd 驱动所需",
        "php-amqplib/php-amqplib": "AMQP 驱动所需",
        "ext-rdkafka": "Kafka 驱动所需"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Queue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Queue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
